# FichaFácil Backend Environment Variables

# REQUIRED: Secret key for JWT signing (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-change-this-in-production

# Database URL (SQLite for MVP, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./data/fichafacil.db

# CORS: Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500

# JWT Settings
ACCESS_TOKEN_EXPIRE_DAYS=30

# Geolocation (optional)
# MAX_DISTANCE_METERS=500
# NEGOCIO_LAT=40.4168
# NEGOCIO_LON=-3.7038
