# FichaFacil MVP - Environment Variables
# Copy this file to .env for local development and set real values there.
# Never commit .env files.

# Database (SQLite for local/demo, PostgreSQL recommended for production)
DATABASE_URL=sqlite+aiosqlite:///./data/fichafacil.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/fichafacil

# JWT Configuration
# DEBUG=true allows a local fallback secret only for development.
# In production (DEBUG=false), SECRET_KEY must be random and at least 32 characters.
SECRET_KEY=replace-with-random-hex-generated-by-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App Settings
APP_NAME=FichaFacil
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
# Preferred production override:
# CORS_ORIGINS=https://your-netlify-app.example

# Geolocation
MAX_DISTANCE_METERS=500

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
