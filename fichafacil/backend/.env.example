# FichaFacil MVP - Environment Variables
# Copy this file to .env for local development only.
# Production should use platform-managed environment variables.
# Never commit .env files.

# Database
# SQLite is the local/demo default. Production should use managed PostgreSQL.
DATABASE_URL=sqlite+aiosqlite:///./data/fichafacil.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/fichafacil

# JWT Configuration
# DEBUG=true allows a local fallback secret only for development.
# In production (DEBUG=false), SECRET_KEY must be random and at least 32 characters.
SECRET_KEY=replac...x-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=***

# App Settings
APP_NAME=FichaFacil
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
# Preferred production override:
# CORS_ORIGINS=https://your-netlify-app.example

# Geolocation
MAX_DISTANCE_METERS=500

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
# Comma-separated IPs/CIDR ranges for direct reverse proxies whose X-Forwarded-For/X-Real-IP headers may be trusted.
# Leave empty unless the deployment platform documents the proxy source ranges.
# TRUSTED_PROXY_IPS=10.0.0.0/24,127.0.0.1
