# FichaFacil MVP - Environment Variables

# Database (SQLite for MVP, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./fichafacil.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/fichafacil

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App Settings
APP_NAME=FichaFacil
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Geolocation
MAX_DISTANCE_METERS=500

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
